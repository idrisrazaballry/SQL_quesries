# Find employee with highest salary.
SELECT *
FROM EMPLOYEE
WHERE salary = (SELECT MAX(salary) FROM EMPLOYEE);


# Find second highest salary (Method 1 – Subquery)
SELECT MAX(salary)
FROM EMPLOYEE
WHERE salary < (SELECT MAX(salary) FROM EMPLOYEE);


# Find second highest salary (Method 2 – DENSE_RANK)
SELECT salary
FROM (
    SELECT salary, DENSE_RANK() OVER (ORDER BY salary DESC) AS rnk
    FROM EMPLOYEE
) 
WHERE rnk = 2;


# Find employees earning more than department average.
SELECT *
FROM EMPLOYEE e
WHERE salary > (
    SELECT AVG(salary)
    FROM EMPLOYEE
    WHERE department = e.department
);

# Name and job of emp working in the same designaation as James
SELECT ENAME, JOB
FROM EMP
WHERE JOB=(SELECT JOB FROM EMP
           WHERE ENAME='JAMES');

# Name, Empno, and annual sal of all emp if their annualSal is greather than words annualSal
SELECT ENAME, EMPNO, SAL*12 AS ANNUALSAL
FROM EMP
WHERE SAL*12 > (SELECT SAL*12 FROM EMP
                WHERE ENAME='WORDS');

__Multi-row Subquery__
# Name and salary for all emp if they are earning less than atleast manager
SELECT ENAME, SAL
FROM EMP
WHERE SAL < ANY (SELECT SAL FROM EMP
                 WHERE JOB='MANAGER');

# Name and hiredate of emp hired before all the manager
SELECT ENAME, HIREDATE
FROM EMP
WHERE HIREDATE < ALL(SELECT HIREDATE FROM EMP
                     WHERE JOB='MANAGER');

# Name of emp hired after all manager and earning sal more than all clerks
SELECT ENAME, HIREDATE
FROM EMP
WHERE HIREDATE > ALL (SELECT HIREDATE FROM EMP
                      WHERE JOB='MANAGER') AND SAL > ALL (SELECT SAL FROM EMP
                                                          WHERE JOB='CLERK');

# Details of emp working as clerk and hired before atleast a salesman
SELECT * FROM EMP
WHERE JOB='CLERK' AND HIREDATE < ANY (SELECT HIREDATE FROM EMP
                                      WHERE JOB='SALESMAN');

# Details of emp working in accounting or sales dept
SELECT * FROM EMP
WHERE DEPTNO IN (SELECT DEPTNO FROM EMP
                 WHERE DNAME IN ('ACCOUNTING','SALES'));

# Dname of emp with name Smith, King and Miller
SELECT DNAME FROM DEPT
WHERE DEPTNO IN (SELECT DEPTNO FROM EMP
                 WHERE ENAME IN ('SMITH', 'KING', 'MILLER'));

# Details of emp working in New York or Chicago
SELECT * FROM EMP
WHERE DEPTNO IN (SELECT DEPTNO FROM DEPT
                 WHERE LOC IN ('NEW YORK', 'CHICAGO'));

# Names if emp are hired after all the emp of deptno 10
SELECT ENAME FROM EMP
WHERE HIREDATE > ALL (SELECT HIREDATE FROM EMP
                       WHERE DEPTNO=10);

# Names of emp earning sal more than salesman
SELECT ENAME FROM EMP
WHERE SAL > ANY (SELECT SAL FROM EMP
                 WHERE JOB='SALESMAN');

