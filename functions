# Number of emp getting salary less than 2000 in deptNo 20
SELECT COUNT(*) FROM EMP
WHERE SAL<2000 AND DEPTNO=20;

# Total salary needed to pay to emp working as clerk
SELECT SUM(SAL)
FROM EMP
WHERE JOB='CLERK';

# Average salary needed to pay all emp
SELECT AVG(SAL)
FROM EMP;

# Number of emp having 'A' as first letter in their name
SELECT COUNT(*)
FROM EMP
WHERE ENAME LIKE 'A%';

# Number of emp working as Clerk OR Manager
SELECT COUNT(*)
FROM EMP
WHERE JOB='CLERK' OR JOB='MANAGER';

