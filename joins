# Joins is used to retrieve the data from multiple tables

1. Cartision join
--> It is used to merge all the records from table1 to table2
Syntax
SELECT *
FROM TB1, TB2;

E.g.,
SELECT *
FROM EMP, DEPT;

2. Inner join/Equi join
--> It is used to give matching records from both tables.
Syntax:
SELECT *
FROM TB1,TB2
WHERE <condition>

E.g.,
SELECT * FROM EMP,DEPT
WHERE EMP.DEPTNO=DEPT.DEPTNO;

QUESTIONS:
# Ename and loc of employee
SELECT ENAME, LOC
FROM EMP,DEPT
WHERE EMP.DEPTNO=DEPT.DEPTNO;

# Deptno, sal and loc of employee
SELECT EMP.DEPTNO, SAL, LOC
FROM EMP,DEPT
WHERE EMP.DEPTNO=DEPT.DEPTNO;

# Hiredate, ename, job, dname and loc of emp
SELECT HIREDATE, ENAME, JOB,DNAME, LOC
FROM EMP,DEPT
WHERE EMP.DEPTNO=DEPT.DEPTNO;

# Ename and loc of emp who is working as analyst
SELECT ENAME, LOC
FROM EMP,DEPT
WHERE EMP.DEPTNO=DEPT.DEPTNO AND EMP.JOB='ANALYST';

# All emp names and their location
SELECT ENAME, LOC
FROM EMP, DEPT
WHERE EMP.DEPTNO=DEPT.DEPTNO;

# Dname and sal for all emp working in Accounting
SELECT DNAME, SAL
FROM EMP,DEPT
WHERE EMP.DEPTNO=DEPT.DEPTNO AND DNAME='ACCOUNTING';

# Dname and annual sal for all emp where sal is more than 2300
SELECT DNAME, SAL*12 AS ANNUALSAL 
FROM EMP,DEPT
WHERE EMP.DEPTNO=DEPT.DEPTNO AND SAL>2300;

# Ename and Dname of emp having character 'A' in their dname
SELECT ENAME, DNAME
FROM EMP,DEPT
WHERE EMP.DEPTNO=DEPT.DEPTNO AND ENAME LIKE '%A%';
