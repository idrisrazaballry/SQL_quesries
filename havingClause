# Having clause is used to filter the group and it execute group by group 

# Number of emp working in each dept except President
SELECT COUNT(*)
FROM EMP
WHERE JOB!='PRESIDENT'
GROUP BY DEPTNO;

# Find departments having average salary greater than 50000
SELECT DEPTNO, AVG(SAL)
FROM EMP
GROUP BY DEPTNO
WHERE AVG(SAL)>50000;

# Find departments having more than 3 employees
SELECT DEPT, COUNT(*)
FROM EMP
GROUP BY DEPT
HAVING COUNT(*)>3;
