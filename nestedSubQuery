# Name, sal from emp whose is getting 3rd minimum sal
SELECT ENAME, SAL
FROM EMP
WHERE SAL=(SELECT MIN(SAL) FROM EMP
           WHERE SAL >(SELECT MIN(SAL) FROM EMP
                       WHERE SAL >(SELECT MIN(SAL) FROM EMP)));

# Name, hiredate of emp hired at first
SELECT ENAME FROM EMP
WHERE HIREDATE=(SELECT MAX(HIREDATE)
                FROM EMP);

# Name, hiredate of emp hired at last
SELECT ENAME FROM EMP
WHERE HIREDATE=(SELECT MIN(HIREDATE)
                FROM EMP);

# Details of emp earning least annual salary
SELECT * FROM EMP
WHERE SAL=(SELECT MIN(SAL*12)
           FROM EMP);

# Name, annual sal of emp if their annual sal is more than all salesman
SELECT ENAME, SAL, SAL*12 AS ANNUALSAL
FROM EMP
WHERE SAL=(SELECT MIN(SAL*12) FROM EMP
           WHERE JOB="SALESMAN");

# 2nd minimum salary
SELECT MIN(SAL) FROM EMP
WHERE SAL >(SELECT MIN(SAL) FROM EMP);

# 5th maximum salary
SELECT MAX(SAL) FROM EMP
WHERE SAL<(SELECT MAX(SAL) FROM EMP
           WHERE SAL<(SELECT MAX(SAL) FROM EMP
                      WHERE SAL<(SELECT MAX(SAL) FROM EMP
                                 WHERE SAL <(SELECT MAX(SAL) FROM EMP))));

# Dname of emp getting 4th max salary
SELECT DNAME FROM DEPT
WHERE DEPTNO=(SELECT DEPTNO FROM EMP
              WHERE SAL=(SELECT MAX(SAL) FROM EMP
                         WHERE SAL <(SELECT MAX(SAL) FROM EMP
                                     WHERE SAL <(SELECT MAX(SAL) FROM EMP
                                                 WHERE SAL <(SELECT MAX(SAL) FROM EMP)))));
