# Name, sal from emp whose is getting 3rd minimum sal
SELECT ENAME, SAL
FROM EMP
WHERE SAL=(SELECT MIN(SAL) FROM EMP
           WHERE SAL >(SELECT MIN(SAL) FROM EMP
                       WHERE SAL >(SELECT MIN(SAL) FROM EMP)));

# Name, hiredate of emp hired at first
SELECT ENAME FROM EMP
WHERE HIREDATE=(SELECT MAX(HIREDATE)
                FROM EMP);

# Name, hiredate of emp hired at last
SELECT ENAME FROM EMP
WHERE HIREDATE=(SELECT MIN(HIREDATE)
                FROM EMP);
